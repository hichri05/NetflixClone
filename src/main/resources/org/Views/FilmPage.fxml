<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1200.0" style="-fx-background-color: #141414;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.netflix.Controllers.FilmPageController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" style="-fx-background-color: rgba(0,0,0,0.9);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label text="NETFLIX" textFill="#e50914">
                    <font><Font name="Arial Black" size="30.0" /></font>
                </Label>
                <HBox alignment="CENTER_LEFT" spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Button style="-fx-background-color: transparent; -fx-cursor: hand;" text="Home" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button style="-fx-background-color: transparent; -fx-cursor: hand;" text="Séries" textFill="#b3b3b3" />
                        <Button style="-fx-background-color: transparent; -fx-cursor: hand;" text="Films" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button style="-fx-background-color: transparent; -fx-cursor: hand;" text="Ma liste" textFill="#b3b3b3" />
                    </children>
                </HBox>
                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <TextField fx:id="searchField" promptText="Titres, genres..." style="-fx-background-color: #333; -fx-text-fill: white; -fx-border-color: #555; -fx-pref-width: 250;" />
                        <Button mnemonicParsing="false" style="-fx-background-color: #e50914; -fx-cursor: hand;" text="Profil" textFill="WHITE">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                    </children>
                </HBox>
            </children>
            <padding><Insets left="50.0" right="50.0" /></padding>
        </HBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" layoutY="70.0" style="-fx-background-color: transparent; -fx-background: #141414;" vbarPolicy="AS_NEEDED" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
            <content>
                <VBox fx:id="categoryContainer" spacing="45.0" style="-fx-background-color: #141414;">
                    <padding><Insets bottom="50.0" top="30.0" /></padding>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>