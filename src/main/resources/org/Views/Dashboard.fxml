<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: #000000; -fx-background: #000000;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.netflix.Controllers.DashboardController">
    <content>
        <VBox spacing="20" style="-fx-background-color: #000000; -fx-padding: 20;">


            <HBox alignment="CENTER_LEFT" spacing="30">
                <Label text="NETFLIX" textFill="#e50914">
                    <font><Font name="System Bold" size="36.0" /></font>
                </Label>
                <Label text="ANALYTICS DASHBOARD" textFill="#e50914">
                    <font><Font size="22.0" /></font>
                </Label>

                <HBox HBox.hgrow="ALWAYS" />
                <VBox spacing="5" style="-fx-background-color: #141414; -fx-padding: 10; -fx-background-radius: 6;">
                    <Label text="Date Range" textFill="WHITE" />
                    <ComboBox fx:id="dateFilter" prefWidth="160"
                              promptText="All Time"
                              style="-fx-background-color: #333; -fx-text-fill: white;" />
                </VBox>
            </HBox>


            <HBox spacing="20">
                <VBox alignment="CENTER" prefHeight="110" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #0a0a0a; -fx-border-color: #333;
                             -fx-border-radius: 6; -fx-background-radius: 6;">
                    <Label text="Movies" textFill="#e50914">
                        <font><Font name="System Bold" size="14" /></font>
                    </Label>
                    <Label fx:id="movieCountLabel" text="0" textFill="#b20710">
                        <font><Font size="40" /></font>
                    </Label>
                </VBox>
                <VBox alignment="CENTER" prefHeight="110" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #0a0a0a; -fx-border-color: #333;
                             -fx-border-radius: 6; -fx-background-radius: 6;">
                    <Label text="Series" textFill="#e50914">
                        <font><Font name="System Bold" size="14" /></font>
                    </Label>
                    <Label fx:id="seriesCountLabel" text="0" textFill="#b20710">
                        <font><Font size="40" /></font>
                    </Label>
                </VBox>
                <VBox alignment="CENTER" prefHeight="110" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #0a0a0a; -fx-border-color: #333;
                             -fx-border-radius: 6; -fx-background-radius: 6;">
                    <Label text="Users" textFill="#e50914">
                        <font><Font name="System Bold" size="14" /></font>
                    </Label>
                    <Label fx:id="userCountLabel" text="0" textFill="#b20710">
                        <font><Font size="40" /></font>
                    </Label>
                </VBox>
            </HBox>


            <GridPane hgap="20" vgap="20">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" />
                    <ColumnConstraints percentWidth="50" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="320" />
                    <RowConstraints minHeight="320" />
                </rowConstraints>


                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0"
                      style="-fx-background-color: #0a0a0a; -fx-border-color: #333;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;">
                    <Label text="Top 5 Categories by Views" textFill="#e50914">
                        <font><Font name="System Bold" size="13" /></font>
                    </Label>
                    <BarChart fx:id="categoryChart"
                              alternativeRowFillVisible="false"
                              horizontalGridLinesVisible="false"
                              legendVisible="false"
                              verticalGridLinesVisible="false"
                              VBox.vgrow="ALWAYS">
                        <xAxis><NumberAxis side="BOTTOM" tickLabelFill="WHITE" /></xAxis>
                        <yAxis><CategoryAxis side="LEFT" tickLabelFill="WHITE" /></yAxis>
                    </BarChart>
                </VBox>


                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0"
                      style="-fx-background-color: #0a0a0a; -fx-border-color: #333;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;">
                    <Label text="Genre Distribution (Film Count)" textFill="#e50914">
                        <font><Font name="System Bold" size="13" /></font>
                    </Label>
                    <PieChart fx:id="genrePieChart"
                              legendVisible="true"
                              labelsVisible="true"
                              VBox.vgrow="ALWAYS"
                              style="-fx-pie-label-visible: true;" />
                </VBox>

                <VBox GridPane.columnIndex="0" GridPane.rowIndex="1"
                      style="-fx-background-color: #0a0a0a; -fx-border-color: #333;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;">
                    <Label text="Top 5 Most Viewed Films" textFill="#e50914">
                        <font><Font name="System Bold" size="13" /></font>
                    </Label>
                    <BarChart fx:id="topFilmsChart"
                              alternativeRowFillVisible="false"
                              horizontalGridLinesVisible="false"
                              legendVisible="false"
                              verticalGridLinesVisible="false"
                              VBox.vgrow="ALWAYS">
                        <xAxis><NumberAxis side="BOTTOM" tickLabelFill="WHITE" /></xAxis>
                        <yAxis><CategoryAxis side="LEFT" tickLabelFill="WHITE" /></yAxis>
                    </BarChart>
                </VBox>


                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1"
                      style="-fx-background-color: #0a0a0a; -fx-border-color: #333;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;">
                    <Label text="New Registrations per Day" textFill="#e50914">
                        <font><Font name="System Bold" size="13" /></font>
                    </Label>
                    <LineChart fx:id="registrationsChart"
                               legendVisible="false"
                               createSymbols="true"
                               VBox.vgrow="ALWAYS">
                        <xAxis>
                            <CategoryAxis side="BOTTOM" tickLabelFill="WHITE"
                                          label="Date" tickLabelRotation="-45" />
                        </xAxis>
                        <yAxis>
                            <NumberAxis side="LEFT" tickLabelFill="WHITE"
                                        label="Users" minorTickVisible="false" />
                        </yAxis>
                    </LineChart>
                </VBox>

            </GridPane>

            <Label text="Data as of Q4 2026" textFill="GRAY" />

        </VBox>
    </content>
</ScrollPane>
