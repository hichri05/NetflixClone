<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fx:id="mainScroll" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #333333;" styleClass="main-scroll-pane" stylesheets="@../Styles/style.css" vbarPolicy="NEVER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.netflix.Controllers.MainController">
   <content>
      <VBox spacing="5.0" style="-fx-background-color: #141414;" stylesheets="@../Styles/style.css">
         <children>
            <BorderPane>
               <left>
                  <Label styleClass="logo" text="NETFLIX" textFill="#e50914" BorderPane.alignment="CENTER">
                     <font>
                        <Font name="System Bold" size="32.0" />
                     </font>
                  </Label>
               </left>
               <center>
                  <HBox id="main-header" alignment="CENTER" spacing="5.0" styleClass="nav-container" stylesheets="@../Styles/style.css" BorderPane.alignment="CENTER">
                     <children>
                        <Label text="Home">
                           <styleClass>
                              <String fx:value="nav-link" />
                              <String fx:value="nav-link-active" />
                           </styleClass></Label>
                        <Label styleClass="nav-link" text="Movies" />
                        <Label styleClass="nav-link" text="TV Shows" />
                        <Label fx:id="Mylist" onMouseClicked="#handleMyListClick" styleClass="nav-link" text="My List" />
                     </children>
                  </HBox>
               </center>
               <VBox.margin>
                  <Insets left="10.0" right="10.0" />
               </VBox.margin>
               <styleClass>
                  <String fx:value="navbar" />
                  <String fx:value="top-nav-bar" />
               </styleClass>
            </BorderPane>
            <StackPane fx:id="heroStack" styleClass="heroStack">
               <children>
                  <VBox alignment="BOTTOM_LEFT" prefHeight="200.0" prefWidth="100.0" spacing="10.0" styleClass="heroStack">
                     <children>
                        <Label fx:id="mvTrendName" styleClass="hero-title" text="Label">
                           <VBox.margin>
                              <Insets bottom="50.0" />
                           </VBox.margin></Label>
                        <Label fx:id="mvTrendDesc" styleClass="hero-description" text="Label">
                           <VBox.margin>
                              <Insets bottom="50.0" />
                           </VBox.margin></Label>
                        <HBox prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" styleClass="btn-play" text="▶ Play" />
                              <Button mnemonicParsing="false" styleClass="btn-mylist" text="+ My List" />
                           </children>
                        </HBox>
                     </children>
                     <StackPane.margin>
                        <Insets />
                     </StackPane.margin>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </children>
            </StackPane>
            <Label styleClass="genre-title" text="Action" />
            <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #141414;" styleClass="movie-row" VBox.vgrow="ALWAYS">
               <content>
                  <HBox fx:id="actionRow" alignment="CENTER" spacing="10.0" style="-fx-background-color: #212121;">
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                  </HBox>
               </content>
            </ScrollPane>
            <Label prefHeight="18.0" prefWidth="538.0" styleClass="genre-title" text="Drama" />
            <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #141414;" styleClass="movie-row">
               <content>
                  <HBox fx:id="dramaRow" alignment="CENTER" spacing="10.0" style="-fx-background-color: #212121;">
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                  </HBox>
               </content>
            </ScrollPane>
         </children>
         <padding>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </padding>
      </VBox>
   </content>
</ScrollPane>
