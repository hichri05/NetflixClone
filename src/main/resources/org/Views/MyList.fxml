<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fx:id="mainScroll" hbarPolicy="NEVER" vbarPolicy="NEVER" fitToWidth="true" style="-fx-background-color: #141414;" stylesheets="@../Styles/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.netflix.Controllers.MyListController">
    <content>
        <VBox minHeight="800" spacing="20.0" style="-fx-background-color: #141414;">
            <children>
                <BorderPane styleClass="top-nav-bar">
                    <left>
                        <Label styleClass="logo" text="NETFLIX" textFill="#e50914">
                            <font><Font name="System Bold" size="32.0" /></font>
                        </Label>
                    </left>
                    <center>
                        <HBox alignment="CENTER" spacing="20.0" styleClass="nav-container">
                            <children>
                                <Label onMouseClicked="#handleHomeClick" styleClass="nav-link" text="Home" />
                                <Label styleClass="nav-link" text="Movies" />
                                <Label styleClass="nav-link" text="TV Shows" />
                                <Label styleClass="nav-link, nav-link-active" text="My List" />
                            </children>
                        </HBox>
                    </center>
                    <VBox.margin><Insets left="10.0" right="10.0" /></VBox.margin>
                </BorderPane>

                <VBox spacing="10.0" style="-fx-padding: 0 40 0 40;">
                    <children>
                        <Label style="-fx-font-size: 32;" styleClass="hero-title" text="My List" />
                        <FlowPane fx:id="listGrid" hgap="15.0" vgap="25.0">
                        </FlowPane>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
