<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>

<AnchorPane prefHeight="720.0" prefWidth="1200.0"
            style="-fx-background-color: #141414;"
            stylesheets="@../Styles/style.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.netflix.Controllers.WatchHistoryController">

    <!-- ── NAVBAR ── -->
    <HBox alignment="CENTER_LEFT" prefHeight="65.0" spacing="20.0"
          style="-fx-background-color: rgba(0,0,0,0.92); -fx-border-color: #1f1f1f; -fx-border-width: 0 0 1 0;"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <padding><Insets left="40.0" right="40.0" /></padding>
        <Label text="NETFLIX" textFill="#e50914"
               style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleBack" text="← Back to Home"
                style="-fx-background-color: transparent; -fx-text-fill: #aaa;
                       -fx-border-color: #555; -fx-border-radius: 4; -fx-background-radius: 4;
                       -fx-cursor: hand; -fx-padding: 7 16;"/>
    </HBox>

    <!-- ── MAIN CONTENT ── -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: #141414;"
                AnchorPane.topAnchor="65.0" AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <content>
            <VBox spacing="0" style="-fx-background-color: #141414;">
                <padding><Insets bottom="60.0" left="50.0" right="50.0" top="36.0" /></padding>

                <!-- Page title -->
                <VBox spacing="6">
                    <Label text="Watch History"
                           style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                    <Label fx:id="subtitleLabel" text="Everything you've watched"
                           style="-fx-text-fill: #666; -fx-font-size: 14px;"/>
                </VBox>

                <Region prefHeight="30" />

                <!-- ── CURRENTLY WATCHING section ── -->
                <VBox fx:id="inProgressSection" spacing="16" managed="true" visible="true">
                    <Label text="CONTINUE WATCHING"
                           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;
                                  -fx-letter-spacing: 1;"/>

                    <!-- Horizontal scroll row of in-progress cards -->
                    <ScrollPane hbarPolicy="NEVER" vbarPolicy="NEVER"
                                style="-fx-background-color: transparent; -fx-background: transparent;">
                        <content>
                            <HBox fx:id="inProgressRow" spacing="16" />
                        </content>
                    </ScrollPane>
                </VBox>

                <Region prefHeight="36" />

                <!-- ── COMPLETED section ── -->
                <VBox spacing="16">
                    <Label text="WATCHED"
                           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;
                                  -fx-letter-spacing: 1;"/>
                    <FlowPane fx:id="completedGrid" hgap="16" vgap="20" />
                </VBox>

                <Region prefHeight="20" />

                <!-- Empty state -->
                <VBox fx:id="emptyState" alignment="CENTER" spacing="16"
                      style="-fx-padding: 80 0 80 0;" visible="false" managed="false">
                    <Label text="🎬"
                           style="-fx-font-size: 56px;"/>
                    <Label text="Your watch history is empty"
                           style="-fx-text-fill: #555; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label text="Start watching something and it'll appear here."
                           style="-fx-text-fill: #333; -fx-font-size: 13px;"/>
                    <Button onAction="#handleBack" text="Browse Content"
                            style="-fx-background-color: #e50914; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-padding: 10 24;
                                   -fx-background-radius: 4; -fx-cursor: hand;"/>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

</AnchorPane>
