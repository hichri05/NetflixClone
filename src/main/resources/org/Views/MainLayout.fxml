<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Text?>

<BorderPane fx:id="mainContainer" prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #141414;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.netflix.Controllers.MainLayoutController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="30" style="-fx-background-color: rgba(0,0,0,0.9); -fx-padding: 15 50 15 50;">

            <Text onMouseClicked="#showHome" style="-fx-fill: #e50914; -fx-font-size: 28; -fx-font-weight: bold; -fx-cursor: hand;" text="NETFLIX" />

            <HBox alignment="CENTER_LEFT" spacing="20">
                <Button onAction="#showHome" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Home" />
                <Button onAction="#showMyList" style="-fx-background-color: transparent; -fx-text-fill: #ccc; -fx-cursor: hand;" text="My List" />
            </HBox>

            <StackPane HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER_RIGHT" spacing="15">
                <TextField promptText="Titles, people, genres" style="-fx-background-color: #333; -fx-text-fill: white; -fx-border-color: #555; -fx-pref-width: 220; -fx-prompt-text-fill: #777;" />
                <Button onAction="#handleLogout" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Logout" />
            </HBox>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentArea" />
    </center>

</BorderPane>