<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.netflix.Controllers.NetflixController"
           styleClass="root-overlay"
           stylesheets="@style.css">

    <Pane styleClass="dark-overlay"/>

    <VBox styleClass="modal-container" maxWidth="900" maxHeight="720"
          alignment="TOP_LEFT">


        <StackPane styleClass="hero-section" minHeight="340">

            <ImageView fx:id="backdropImage" fitWidth="900" fitHeight="340"
                       preserveRatio="false" styleClass="backdrop-image"/>

            <Pane styleClass="backdrop-gradient"/>

            <HBox alignment="TOP_RIGHT" styleClass="close-btn-wrapper">
                <Button fx:id="closeBtn" styleClass="close-btn" text="✕"
                        onAction="#handleClose"/>
            </HBox>

            <VBox alignment="BOTTOM_LEFT" styleClass="hero-content-box">

                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label styleClass="netflix-n" text="N"/>
                    <Label styleClass="movie-badge" text="M O V I E"/>
                </HBox>

                <Label fx:id="titleLabel" styleClass="hero-title" text="THE QUANTUM HEIST"
                       wrapText="true"/>

                <Label fx:id="taglineLabel" styleClass="hero-tagline"
                       text="Saving time before it runs out"/>

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="progress-row">
                    <ProgressBar fx:id="watchProgress" styleClass="watch-progress"
                                 progress="0.078" prefWidth="360" prefHeight="4"/>
                    <Label fx:id="progressLabel" styleClass="progress-label"
                           text="10 of 128m"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="action-row">
                    <Button fx:id="resumeBtn" styleClass="resume-btn"
                            text="▶  Resume" onAction="#handleResume"/>
                    <Button styleClass="icon-btn" text="✓" onAction="#handleAddToList"/>
                    <Button styleClass="icon-btn" text="👍" onAction="#handleLike"/>
                    <Button styleClass="icon-btn" text="👎" onAction="#handleDislike"/>
                    <Label styleClass="match-label-hero" text="Match"/>
                </HBox>
            </VBox>

            <VBox alignment="TOP_RIGHT" styleClass="hero-rating-box">
                <HBox fx:id="userRatingStars" styleClass="stars-row" spacing="2"/>
                <HBox fx:id="criticRatingStars" styleClass="stars-row" spacing="2"/>
            </VBox>

        </StackPane>


        <HBox styleClass="details-section" spacing="24">
            <VBox styleClass="left-col" spacing="12" HBox.hgrow="ALWAYS">

                <Label fx:id="detailTitleLabel" styleClass="detail-title"
                       text="THE QUANTUM HEIST"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="yearLabel" styleClass="meta-label" text="2024"/>
                    <Label styleClass="rating-badge" text="R"/>
                    <Label fx:id="durationLabel" styleClass="meta-label" text="2h 8m"/>
                    <Label styleClass="meta-label ad-badge" text="AD›"/>
                </HBox>

                <Label fx:id="descriptionLabel" styleClass="description-text"
                       wrapText="true" maxWidth="440"
                       text="A brilliant but disgraced physicist must use her unauthorized time-travel technology to pull off the ultimate heist: stealing a crucial historical artifact before a catastrophic paradox occurs. Can she and her ragtag team succeed?"/>

                <FlowPane fx:id="genreTagsPane" styleClass="genre-tags-pane"
                          hgap="8" vgap="8"/>

            </VBox>

            <VBox styleClass="right-col" spacing="14" minWidth="280">

                <HBox alignment="CENTER_LEFT" spacing="0">
                    <Label styleClass="section-label" text="CAST"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="matchPctLabel" styleClass="match-percent"
                           text="96% Match"/>
                </HBox>

                <HBox fx:id="castRow" spacing="10" alignment="CENTER_LEFT"/>

                <HBox fx:id="castNamesRow" spacing="12" alignment="CENTER_LEFT"/>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label styleClass="info-key" text="Director:"/>
                    <Label fx:id="directorLabel" styleClass="info-val" text="—"/>
                </HBox>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label styleClass="info-key" text="Genres:"/>
                    <Label fx:id="genresTextLabel" styleClass="info-val"
                           text="Sci-Fi, Thriller, Action, Adventure" wrapText="true"
                           maxWidth="200"/>
                </HBox>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label styleClass="info-key" text="This movie is:"/>
                    <Label fx:id="moodLabel" styleClass="info-val green-text"
                           text="Exciting, Gritty"/>
                </HBox>

                <Separator styleClass="divider"/>

                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="section-label" text="USER REVIEWS"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="addReviewBtn" styleClass="add-review-btn"
                            text="ADD YOUR REVIEW" />
                </HBox>

                <ScrollPane styleClass="reviews-scroll" fitToWidth="true"
                            prefHeight="140" hbarPolicy="NEVER">
                    <VBox fx:id="reviewsContainer" spacing="10" styleClass="reviews-vbox"/>
                </ScrollPane>

            </VBox>
        </HBox>
    </VBox>
</StackPane>
