<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="mainScroll" fitToWidth="true" style="-fx-background-color: #141414;" stylesheets="@../Styles/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.netflix.Controllers.MediaDetailsController">
    <content>
        <VBox spacing="30.0" style="-fx-background-color: #141414;">
            <children>
                <StackPane fx:id="detailHero" prefHeight="450.0">
                    <children>
                        <ImageView fx:id="backgroundImage" pickOnBounds="true" preserveRatio="true" />
                        <VBox alignment="BOTTOM_LEFT" spacing="15.0" style="-fx-background-color: linear-gradient(to top, #141414, transparent);">
                            <children>
                                <Button fx:id="backButton" alignment="TOP_LEFT" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16px; -fx-cursor: hand;" text="← Back" />
                                <Label fx:id="titleLabel" styleClass="hero-title" text="SERIES TITLE" />
                                <HBox spacing="15.0">
                                    <children>
                                        <Button fx:id="playbtn" onAction="#handlePlay" styleClass="btn-play" text="▶ Play" />
                                        <Button fx:id="mylistbtn" onAction="#handleAddToMyList" styleClass="btn-mylist" text="+ My List" />
                                    </children>
                                </HBox>
                                <Label fx:id="descriptionLabel" maxWidth="600.0" styleClass="hero-description" text="Summary of the show ..." wrapText="true" />
                                <HBox fx:id="ratingBox" alignment="CENTER_LEFT" spacing="5.0">
                                    <Label fx:id="star1" styleClass="star-btn" text="★" onMouseClicked="#handleRate" userData="1" />
                                    <Label fx:id="star2" styleClass="star-btn" text="★" onMouseClicked="#handleRate" userData="2" />
                                    <Label fx:id="star3" styleClass="star-btn" text="★" onMouseClicked="#handleRate" userData="3" />
                                    <Label fx:id="star4" styleClass="star-btn" text="★" onMouseClicked="#handleRate" userData="4" />
                                    <Label fx:id="star5" styleClass="star-btn" text="★" onMouseClicked="#handleRate" userData="5" />
                                    <Label fx:id="ratingLabel" style="-fx-text-fill: #aaa; -fx-font-size: 13px;" text="" />
                                </HBox>
                            </children>
                            <padding><Insets bottom="40.0" left="50.0" /></padding>
                        </VBox>
                    </children>
                </StackPane>

                <!-- CASTING -->
                <VBox spacing="10.0" style="-fx-padding: 0 50 0 50;">
                    <children>
                        <Label styleClass="genre-title" text="Cast" />
                        <ScrollPane hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <HBox fx:id="castingContainer" spacing="20.0" style="-fx-padding: 10 0 10 0;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <!-- EPISODES — only visible for series -->
                <VBox fx:id="episodesSection" spacing="10.0" style="-fx-padding: 0 50 0 50;" visible="false" managed="false">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <Label styleClass="genre-title" text="Episodes" />
                                <ChoiceBox fx:id="seasonSelector" style="-fx-background-color: #333; -fx-text-fill: white;" />
                            </children>
                        </HBox>
                        <VBox fx:id="episodeListContainer" spacing="10.0" />
                    </children>
                </VBox>

                <!-- MORE LIKE THIS -->
                <VBox spacing="10.0" style="-fx-padding: 0 50 40 50;">
                    <children>
                        <Label styleClass="genre-title" text="More Like This" />
                        <FlowPane fx:id="relatedGrid" hgap="15.0" vgap="15.0" />
                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>