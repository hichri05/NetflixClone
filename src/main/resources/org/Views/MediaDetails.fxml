<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="mainScroll" fitToWidth="true" style="-fx-background-color: #141414;"
            stylesheets="@../Styles/style.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.netflix.Controllers.MediaDetailsController">
    <content>
        <VBox spacing="30.0" style="-fx-background-color: #141414;">
            <children>

                <!-- HERO SECTION -->
                <StackPane fx:id="detailHero" prefHeight="450.0">
                    <children>
                        <ImageView fx:id="backgroundImage" pickOnBounds="true" preserveRatio="true" />
                        <VBox alignment="BOTTOM_LEFT" spacing="15.0"
                              style="-fx-background-color: linear-gradient(to top, #141414, transparent);">
                            <children>
                                <Button fx:id="backButton" onAction="#handleBack" styleClass="btn-back" text="← Back" />
                                <Label fx:id="titleLabel" styleClass="hero-title" text="TITLE" />
                                <HBox spacing="15.0">
                                    <children>
                                        <Button fx:id="playbtn" onAction="#handlePlay" styleClass="btn-play" text="▶ Play" />
                                        <Button fx:id="mylistbtn" onAction="#handleAddToMyList" styleClass="btn-mylist" text="+ My List" />
                                    </children>
                                </HBox>
                                <Label fx:id="descriptionLabel" maxWidth="600.0" styleClass="hero-description" wrapText="true" />
                                <HBox fx:id="ratingBox" alignment="CENTER_LEFT" spacing="5.0">
                                    <Label fx:id="star1" onMouseClicked="#handleRate" styleClass="star-btn" text="★" userData="1" />
                                    <Label fx:id="star2" onMouseClicked="#handleRate" styleClass="star-btn" text="★" userData="2" />
                                    <Label fx:id="star3" onMouseClicked="#handleRate" styleClass="star-btn" text="★" userData="3" />
                                    <Label fx:id="star4" onMouseClicked="#handleRate" styleClass="star-btn" text="★" userData="4" />
                                    <Label fx:id="star5" onMouseClicked="#handleRate" styleClass="star-btn" text="★" userData="5" />
                                    <Label fx:id="ratingLabel" style="-fx-text-fill: #aaa;" text="" />
                                </HBox>
                            </children>
                            <padding><Insets bottom="40.0" left="50.0" /></padding>
                        </VBox>
                    </children>
                </StackPane>

                <!-- CAST SECTION -->
                <VBox spacing="10.0" style="-fx-padding: 0 50 0 50;">
                    <children>
                        <Label styleClass="section-title" text="Cast" />
                        <ScrollPane hbarPolicy="NEVER" vbarPolicy="NEVER"
                                    style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <HBox fx:id="castingContainer" spacing="25.0" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <!-- SEASON / EPISODE BAR (only visible for series) -->
                <VBox fx:id="seasonEpisodeBar" spacing="12.0" visible="false" managed="false"
                      style="-fx-padding: 0 50 0 50;">
                    <children>
                        <Label styleClass="section-title" text="Episodes" />
                        <HBox spacing="15.0" alignment="CENTER_LEFT">
                            <children>
                                <Label style="-fx-text-fill: #aaa; -fx-font-size: 14px;" text="Season:" />
                                <ComboBox fx:id="seasonComboBox" onAction="#handleSeasonChange"
                                          style="-fx-background-color: #333; -fx-text-fill: white; -fx-font-size: 13px;"
                                          prefWidth="150" />
                            </children>
                        </HBox>
                        <ScrollPane hbarPolicy="ALWAYS" vbarPolicy="NEVER"
                                    style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <HBox fx:id="episodesContainer" spacing="15.0" style="-fx-padding: 5 0 10 0;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <!-- TAB BUTTONS: More Like This | Comments -->
                <VBox spacing="0" style="-fx-padding: 0 50 0 50;">
                    <children>
                        <!-- Tab Header -->
                        <HBox fx:id="tabHeader" spacing="0" style="-fx-border-color: #333; -fx-border-width: 0 0 2 0;">
                            <children>
                                <Button fx:id="tabMoreLikeThis" onAction="#handleTabMoreLikeThis"
                                        text="More Like This"
                                        style="-fx-background-color: transparent; -fx-text-fill: white;
                                               -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;
                                               -fx-border-color: #e50914; -fx-border-width: 0 0 3 0;
                                               -fx-padding: 10 20 10 0;" />
                                <Button fx:id="tabComments" onAction="#handleTabComments"
                                        text="Comments"
                                        style="-fx-background-color: transparent; -fx-text-fill: #aaa;
                                               -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;
                                               -fx-border-color: transparent; -fx-border-width: 0 0 3 0;
                                               -fx-padding: 10 20 10 20;" />
                            </children>
                        </HBox>

                        <!-- Tab Content: More Like This -->
                        <VBox fx:id="panelMoreLikeThis" spacing="15.0" style="-fx-padding: 20 0 20 0;">
                            <children>
                                <FlowPane fx:id="relatedGrid" hgap="15.0" vgap="15.0" />
                            </children>
                        </VBox>

                        <!-- Tab Content: Comments (hidden by default) -->
                        <VBox fx:id="panelComments" spacing="15.0" visible="false" managed="false"
                              style="-fx-padding: 20 0 50 0;">
                            <children>
                                <VBox fx:id="commentsListContainer" spacing="15.0" />
                                <VBox spacing="10.0" styleClass="comment-input-area">
                                    <children>
                                        <TextArea fx:id="newCommentField" prefRowCount="3"
                                                  promptText="Écrire un commentaire..."
                                                  styleClass="comment-text-area" wrapText="true" />
                                        <HBox alignment="CENTER_RIGHT">
                                            <Button onAction="#handlePublishComment"
                                                    styleClass="btn-publish" text="Publier" />
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>
