<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="mainScroll" fitToWidth="true" style="-fx-background-color: #141414;" stylesheets="@../Styles/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.netflix.Controllers.MediaDetailsController">
    <content>
        <VBox spacing="30.0" style="-fx-background-color: #141414;">
            <children>
                <StackPane fx:id="detailHero" prefHeight="450.0">
                    <children>
                        <ImageView fx:id="backgroundImage" pickOnBounds="true" preserveRatio="true" />
                        <VBox alignment="BOTTOM_LEFT" spacing="15.0" style="-fx-background-color: linear-gradient(to top, #141414, transparent);">
                            <children>
                                <Button fx:id="backButton" onAction="#handleBack" styleClass="btn-back" text="← Back" />
                                <Label fx:id="titleLabel" styleClass="hero-title" text="TITLE" />
                                <HBox spacing="15.0">
                                    <children>
                                        <Button fx:id="playbtn" onAction="#handlePlay" styleClass="btn-play" text="▶ Play" />
                                        <Button fx:id="mylistbtn" onAction="#handleAddToMyList" styleClass="btn-mylist" text="+ My List" />
                                    </children>
                                </HBox>
                                <Label fx:id="descriptionLabel" maxWidth="600.0" styleClass="hero-description" wrapText="true" />
                                <HBox fx:id="ratingBox" alignment="CENTER_LEFT" spacing="5.0">
                                    <Label fx:id="star1" onMouseClicked="#handleRate" styleClass="star-btn" text="★" userData="1" />
                                    <Label fx:id="star2" onMouseClicked="#handleRate" styleClass="star-btn" text="★" userData="2" />
                                    <Label fx:id="star3" onMouseClicked="#handleRate" styleClass="star-btn" text="★" userData="3" />
                                    <Label fx:id="star4" onMouseClicked="#handleRate" styleClass="star-btn" text="★" userData="4" />
                                    <Label fx:id="star5" onMouseClicked="#handleRate" styleClass="star-btn" text="★" userData="5" />
                                    <Label fx:id="ratingLabel" style="-fx-text-fill: #aaa;" text="" />
                                </HBox>
                            </children>
                            <padding><Insets bottom="40.0" left="50.0" /></padding>
                        </VBox>
                    </children>
                </StackPane>

                <VBox spacing="10.0" style="-fx-padding: 0 50 0 50;">
                    <children>
                        <Label styleClass="section-title" text="Cast" />
                        <ScrollPane hbarPolicy="NEVER" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <HBox fx:id="castingContainer" spacing="25.0" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <VBox spacing="10.0" style="-fx-padding: 0 50 20 50;">
                    <children>
                        <Label styleClass="section-title" text="More Like This" />
                        <FlowPane fx:id="relatedGrid" hgap="15.0" vgap="15.0" />
                    </children>
                </VBox>

                <VBox spacing="15.0" style="-fx-padding: 0 50 50 50;">
                    <children>
                        <Label styleClass="section-title" text="Commentaires" />
                        <VBox fx:id="commentsListContainer" spacing="15.0" />
                        <VBox spacing="10.0" styleClass="comment-input-area">
                            <children>
                                <TextArea fx:id="newCommentField" prefRowCount="3" promptText="Écrire un commentaire..." styleClass="comment-text-area" wrapText="true" />
                                <HBox alignment="CENTER_RIGHT">
                                    <Button onAction="#handlePublishComment" styleClass="btn-publish" text="Publier" />
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>