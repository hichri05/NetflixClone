<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefWidth="860" prefHeight="560" spacing="0"
      style="-fx-background-color: #141414;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.netflix.Controllers.EpisodeController">

    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color: #1a1a1a; -fx-border-color: #2a2a2a; -fx-border-width: 0 0 1 0;">
        <padding><Insets top="18" right="28" bottom="18" left="28"/></padding>

        <VBox spacing="3">
            <Label text="EPISODE MANAGER"
                   style="-fx-text-fill: #e50914; -fx-font-size: 10px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
            <Text fx:id="seriesTitleHeader"
                  text="Manage Episodes"
                  style="-fx-fill: #ffffff; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="✕  Close" onAction="#handleClose"
                style="-fx-background-color: #2a2a2a; -fx-text-fill: #aaaaaa;
                       -fx-border-color: #3a3a3a; -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 8 16 8 16;"/>
    </HBox>

    <HBox spacing="0" VBox.vgrow="ALWAYS">

        <VBox prefWidth="270" spacing="0"
              style="-fx-background-color: #1a1a1a; -fx-border-color: #2a2a2a; -fx-border-width: 0 1 0 0;">
            <padding><Insets top="24" right="20" bottom="24" left="20"/></padding>

            <Label text="Add Episode"
                   style="-fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Label text="Fill in the fields below"
                   style="-fx-text-fill: #666666; -fx-font-size: 12px;"/>

            <Region prefHeight="20"/>
            <Separator style="-fx-background-color: #2a2a2a;"/>
            <Region prefHeight="20"/>

            <Label text="SEASON"
                   style="-fx-text-fill: #888888; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <Region prefHeight="6"/>
            <Spinner fx:id="seasonSpinner" editable="true" maxWidth="Infinity"
                     style="-fx-background-color: #242424; -fx-text-fill: #ffffff;
                            -fx-border-color: #333333; -fx-border-radius: 6; -fx-background-radius: 6;
                            -fx-font-size: 13px;"/>

            <Region prefHeight="16"/>

            <Label text="EPISODE"
                   style="-fx-text-fill: #888888; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <Region prefHeight="6"/>
            <Spinner fx:id="episodeSpinner" editable="true" maxWidth="Infinity"
                     style="-fx-background-color: #242424; -fx-text-fill: #ffffff;
                            -fx-border-color: #333333; -fx-border-radius: 6; -fx-background-radius: 6;
                            -fx-font-size: 13px;"/>

            <Region prefHeight="16"/>

            <Label text="TITLE  (optional)"
                   style="-fx-text-fill: #888888; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <Region prefHeight="6"/>
            <TextField fx:id="epTitle" promptText="e.g. Pilot"
                       style="-fx-background-color: #242424; -fx-text-fill: #ffffff;
                              -fx-prompt-text-fill: #555555;
                              -fx-border-color: #333333; -fx-border-radius: 6; -fx-background-radius: 6;
                              -fx-font-size: 13px; -fx-padding: 8 10 8 10;"/>

            <Region prefHeight="16"/>

            <Label text="VIDEO URL"
                   style="-fx-text-fill: #888888; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <Region prefHeight="6"/>
            <TextField fx:id="epVideoUrl" promptText="https://..."
                       style="-fx-background-color: #242424; -fx-text-fill: #ffffff;
                              -fx-prompt-text-fill: #555555;
                              -fx-border-color: #333333; -fx-border-radius: 6; -fx-background-radius: 6;
                              -fx-font-size: 13px; -fx-padding: 8 10 8 10;"/>

            <Region prefHeight="24"/>

            <Button text="＋  Add to Series" onAction="#handleAddEpisode"
                    maxWidth="Infinity"
                    style="-fx-background-color: #e50914; -fx-text-fill: #ffffff;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-border-radius: 6; -fx-background-radius: 6;
                           -fx-cursor: hand; -fx-padding: 10 0 10 0;"/>
        </VBox>

        <VBox spacing="0" HBox.hgrow="ALWAYS">
            <padding><Insets top="24" right="28" bottom="20" left="28"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <padding><Insets bottom="14"/></padding>
                <Label text="Episodes"
                       style="-fx-text-fill: #ffffff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            </HBox>

            <TableView fx:id="episodeTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #1e1e1e; -fx-border-color: #2a2a2a;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-table-header-border-color: transparent;
                              -fx-faint-focus-color: transparent;
                              -fx-focus-color: transparent;">
                <columns>
                    <TableColumn fx:id="colSeason"  text="Season"     prefWidth="90"  minWidth="70"/>
                    <TableColumn fx:id="colNumber"  text="Episode"    prefWidth="90"  minWidth="70"/>
                    <TableColumn fx:id="colTitle"   text="Title"      prefWidth="160" minWidth="100"/>
                    <TableColumn fx:id="colUrl"     text="Video Path" minWidth="200"/>
                </columns>
                <placeholder>
                    <VBox alignment="CENTER" spacing="8">
                        <Label text="No episodes yet"
                               style="-fx-text-fill: #555555; -fx-font-size: 14px;"/>
                        <Label text="Add one using the panel on the left."
                               style="-fx-text-fill: #444444; -fx-font-size: 12px;"/>
                    </VBox>
                </placeholder>
            </TableView>

            <Region prefHeight="14"/>

            <HBox alignment="CENTER_RIGHT">
                <Button text="Remove Selected" onAction="#handleDeleteEpisode"
                        style="-fx-background-color: transparent; -fx-text-fill: #cc3333;
                               -fx-border-color: #cc3333; -fx-border-radius: 6; -fx-background-radius: 6;
                               -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 7 14 7 14;"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
