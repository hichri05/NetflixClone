<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefWidth="700" spacing="20" style="-fx-background-color: #1b1b1b;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.netflix.Controllers.EpisodeController">
    <padding><Insets bottom="25" left="25" right="25" top="25" /></padding>

    <Text fx:id="seriesTitleHeader" style="-fx-fill: #e50914; -fx-font-size: 22; -fx-font-weight: bold;" text="Manage Episodes" />

    <HBox spacing="20">
        <VBox prefWidth="250" spacing="15" style="-fx-background-color: #222; -fx-padding: 15; -fx-background-radius: 5;">
            <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Add New Episode" />

            <VBox spacing="5">
                <Label style="-fx-text-fill: #aaa;" text="Season Number" />
                <Spinner fx:id="seasonSpinner" editable="true" maxWidth="Infinity" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-text-fill: #aaa;" text="Episode Number" />
                <Spinner fx:id="episodeSpinner" editable="true" maxWidth="Infinity" />
            </VBox>

            <VBox spacing="5">
                <Label style="-fx-text-fill: #aaa;" text="Video URL" />
                <TextField fx:id="epVideoUrl" style="-fx-background-color: #333; -fx-text-fill: white;" />
            </VBox>

            <Button maxWidth="Infinity" onAction="#handleAddEpisode" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-font-weight: bold;" text="Add to Series" />
        </VBox>

        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <TableView fx:id="episodeTable" style="-fx-background-color: #1b1b1b;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colSeason" prefWidth="80" text="Season" />
                    <TableColumn fx:id="colNumber" prefWidth="80" text="Ep #" />
                    <TableColumn fx:id="colUrl" prefWidth="240" text="Video Path" />
                </columns>
            </TableView>
            <Button onAction="#handleDeleteEpisode" style="-fx-background-color: transparent; -fx-text-fill: #ff4444; -fx-border-color: #ff4444;" text="Remove Selected" />
        </VBox>
    </HBox>

    <HBox alignment="CENTER_RIGHT">
        <Button onAction="#handleClose" style="-fx-background-color: #444; -fx-text-fill: white;" text="Close" />
    </HBox>
</VBox>
