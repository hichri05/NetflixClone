<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootPane" prefHeight="720.0" prefWidth="1280.0"
           style="-fx-background-color: black;"
           stylesheets="@../Styles/style.css"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.netflix.Controllers.VideoPlayerController">
    <children>

        <!-- ── VIDEO ── -->
        <MediaView fx:id="mediaView" />

        <!-- ── CONTROLS OVERLAY ── -->
        <VBox alignment="BOTTOM_CENTER" spacing="10.0"
              style="-fx-background-color: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.3) 60%, transparent 100%);">
            <children>

                <!-- Top bar: back + title -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Button onAction="#handleBack"
                                style="-fx-background-color: rgba(0,0,0,0.5); -fx-text-fill: white;
                                       -fx-cursor: hand; -fx-border-radius: 4; -fx-background-radius: 4;
                                       -fx-padding: 6 14;"
                                text="← Back">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <VBox spacing="2">
                            <Label fx:id="videoTitle"
                                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"
                                   text="Movie Title" />
                            <Label fx:id="episodeSubtitle"
                                   style="-fx-text-fill: #aaa; -fx-font-size: 13px;"
                                   text="" />
                        </VBox>
                    </children>
                    <VBox.margin><Insets top="-520.0" /></VBox.margin>
                    <padding><Insets left="24.0" top="24.0" /></padding>
                </HBox>

                <Region prefHeight="440.0" prefWidth="1280.0" />

                <!-- Progress slider -->
                <Slider fx:id="timeSlider" style="-fx-cursor: hand;" prefHeight="6">
                    <padding><Insets left="24.0" right="24.0" /></padding>
                </Slider>

                <!-- Bottom controls bar -->
                <HBox alignment="CENTER_LEFT" spacing="16.0"
                      style="-fx-padding: 4 24 20 24;">
                    <children>

                        <!-- Play/Pause -->
                        <Button fx:id="playBtn" onAction="#togglePlay"
                                style="-fx-background-color: transparent; -fx-text-fill: white;
                                       -fx-font-size: 22; -fx-cursor: hand; -fx-padding: 2 6;"
                                text="▶" />

                        <!-- Rewind 10s -->
                        <Button onAction="#handleRewind"
                                style="-fx-background-color: transparent; -fx-text-fill: white;
                                       -fx-font-size: 14; -fx-cursor: hand;"
                                text="⟲ 10s" />

                        <!-- Forward 10s -->
                        <Button onAction="#handleForward"
                                style="-fx-background-color: transparent; -fx-text-fill: white;
                                       -fx-font-size: 14; -fx-cursor: hand;"
                                text="10s ⟳" />

                        <!-- Time label -->
                        <Label fx:id="timeLabel" id="timeLabel"
                               style="-fx-text-fill: #ccc; -fx-font-family: 'Monospaced'; -fx-font-size: 13px;"
                               text="00:00 / 00:00" />

                        <!-- Next episode button (series only) -->
                        <Button fx:id="nextEpisodeBtn" onAction="#handleNextEpisode"
                                style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                                       -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 4;
                                       -fx-background-radius: 4; -fx-font-size: 12px;
                                       -fx-cursor: hand; -fx-padding: 5 14;"
                                text="Next ▶▶"
                                visible="false" managed="false" />

                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Volume icon + slider -->
                        <Label text="🔊" style="-fx-text-fill: white; -fx-font-size: 16px;" />
                        <Slider fx:id="volumeSlider" prefWidth="120.0" value="70.0" />

                        <!-- FULLSCREEN button -->
                        <Button fx:id="fullscreenBtn" onAction="#handleFullscreen"
                                style="-fx-background-color: transparent; -fx-text-fill: white;
                                       -fx-font-size: 18px; -fx-cursor: hand; -fx-padding: 2 6;"
                                text="⛶" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- ══════════════════════════════════════════════════ -->
        <!--  BINGE-WATCHING NEXT EPISODE OVERLAY              -->
        <!-- ══════════════════════════════════════════════════ -->
        <VBox fx:id="nextEpisodeOverlay"
              visible="false" managed="false"
              alignment="CENTER_RIGHT"
              style="-fx-background-color: transparent;"
              StackPane.alignment="BOTTOM_RIGHT">
            <children>

                <VBox fx:id="nextEpisodeCard"
                      spacing="0"
                      style="-fx-background-color: rgba(18,18,18,0.97);
                             -fx-background-radius: 10;
                             -fx-border-color: rgba(255,255,255,0.08);
                             -fx-border-radius: 10;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.9), 40, 0.4, 0, 0);"
                      prefWidth="340">
                    <children>

                        <!-- Thumbnail -->
                        <StackPane>
                            <ImageView fx:id="nextEpThumbnail"
                                       fitWidth="340" fitHeight="190"
                                       preserveRatio="false" />
                            <VBox style="-fx-background-color: linear-gradient(to top, rgba(18,18,18,0.95), transparent);" />

                            <!-- Countdown ring -->
                            <StackPane StackPane.alignment="TOP_RIGHT">
                                <padding><Insets top="10" right="10" /></padding>
                                <StackPane prefWidth="50" prefHeight="50"
                                           style="-fx-background-color: rgba(0,0,0,0.8);
                                                  -fx-background-radius: 25;
                                                  -fx-border-color: #e50914; -fx-border-radius: 25; -fx-border-width: 2;">
                                    <Label fx:id="countdownLabel" text="10"
                                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
                                </StackPane>
                            </StackPane>
                        </StackPane>

                        <!-- Red countdown bar -->
                        <ProgressBar fx:id="countdownBar" progress="1.0"
                                     prefWidth="340" prefHeight="3"
                                     style="-fx-accent: #e50914; -fx-background-color: #333; -fx-padding: 0;" />

                        <!-- Info -->
                        <VBox spacing="5" style="-fx-padding: 14 16 0 16;">
                            <Label text="UP NEXT"
                                   style="-fx-text-fill: #e50914; -fx-font-size: 9px;
                                          -fx-font-weight: bold; -fx-letter-spacing: 2;" />
                            <Label fx:id="nextEpTitle" text="Episode Title"
                                   style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"
                                   wrapText="true" maxWidth="308" />
                            <Label fx:id="nextEpDesc" text=""
                                   style="-fx-text-fill: #888; -fx-font-size: 12px;"
                                   wrapText="true" maxWidth="308" maxHeight="36" />
                        </VBox>

                        <!-- Buttons -->
                        <HBox spacing="10" alignment="CENTER"
                              style="-fx-padding: 12 16 16 16;">
                            <Button onAction="#handlePlayNext"
                                    style="-fx-background-color: white; -fx-text-fill: black;
                                           -fx-font-weight: bold; -fx-font-size: 13px;
                                           -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 9 22;"
                                    text="▶  Play Now"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Button onAction="#handleCancelNext"
                                    style="-fx-background-color: transparent; -fx-text-fill: #aaa;
                                           -fx-border-color: #444; -fx-border-radius: 4; -fx-background-radius: 4;
                                           -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 9 16;"
                                    text="Cancel" />
                        </HBox>
                    </children>
                </VBox>
            </children>
            <padding><Insets bottom="80" right="40" /></padding>
        </VBox>

    </children>
</StackPane>
