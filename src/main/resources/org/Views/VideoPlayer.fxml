<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Arc?>

<StackPane fx:id="rootPane" prefHeight="720.0" prefWidth="1280.0"
           style="-fx-background-color: black;"
           stylesheets="@../Styles/style.css"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.netflix.Controllers.VideoPlayerController">
    <children>

        <MediaView fx:id="mediaView" />

        <VBox alignment="BOTTOM_CENTER" spacing="10.0"
              style="-fx-background-color: linear-gradient(to top, rgba(0,0,0,0.85), transparent);">
            <children>

                <!-- Top bar: back + title -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Button onAction="#handleBack"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"
                                text="← Back">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Button>
                        <Label fx:id="videoTitle" style="-fx-text-fill: white;" text="Movie Title">
                            <font><Font size="20.0" /></font>
                        </Label>
                        <!-- Episode subtitle (shown only for series) -->
                        <Label fx:id="episodeSubtitle"
                               style="-fx-text-fill: #aaa; -fx-font-size: 14px;"
                               text="" />
                    </children>
                    <VBox.margin><Insets top="-600.0" /></VBox.margin>
                    <padding><Insets left="20.0" top="20.0" /></padding>
                </HBox>

                <Region prefHeight="530.0" prefWidth="1280.0" />


                <Slider fx:id="timeSlider" style="-fx-cursor: hand;">
                    <padding><Insets left="20.0" right="20.0" /></padding>
                </Slider>


                <HBox alignment="CENTER_LEFT" spacing="20.0"
                      style="-fx-padding: 0 20 20 20;">
                    <children>
                        <Button fx:id="playBtn" onAction="#togglePlay"
                                style="-fx-background-color: transparent; -fx-text-fill: white;
                                       -fx-font-size: 18; -fx-cursor: hand;"
                                text="▶" />
                        <Label fx:id="timeLabel" id="timeLabel"
                               style="-fx-text-fill: white; -fx-font-family: 'Monospaced';"
                               text="00:00 / 00:00">
                            <font><Font size="14.0" /></font>
                        </Label>
                        <Button onAction="#handleRewind"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"
                                text="⟲ 10s" />
                        <Button onAction="#handleForward"
                                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"
                                text="10s ⟳" />


                        <Button fx:id="nextEpisodeBtn" onAction="#handleNextEpisode"
                                style="-fx-background-color: transparent; -fx-text-fill: #aaa;
                                       -fx-border-color: #555; -fx-border-radius: 4; -fx-background-radius: 4;
                                       -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 4 14;"
                                text="Next Episode ▶▶"
                                visible="false" managed="false" />

                        <Region HBox.hgrow="ALWAYS" />
                        <Slider fx:id="volumeSlider" prefWidth="150.0" value="50.0" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox fx:id="nextEpisodeOverlay"
              visible="false" managed="false"
              alignment="CENTER_RIGHT"
              style="-fx-background-color: transparent;"
              StackPane.alignment="BOTTOM_RIGHT">
            <children>


                <VBox fx:id="nextEpisodeCard"
                      spacing="12"
                      style="-fx-background-color: rgba(20,20,20,0.96);
                             -fx-background-radius: 12;
                             -fx-border-color: rgba(255,255,255,0.1);
                             -fx-border-radius: 12;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.8), 30, 0.5, 0, 0);"
                      prefWidth="340">
                    <children>


                        <StackPane>
                            <ImageView fx:id="nextEpThumbnail"
                                       fitWidth="340" fitHeight="190"
                                       preserveRatio="false"
                                       style="-fx-background-radius: 12 12 0 0;" />

                            <VBox style="-fx-background-color: linear-gradient(to top, rgba(20,20,20,0.9), transparent);
                                         -fx-background-radius: 0;" />

                            <StackPane StackPane.alignment="TOP_RIGHT">
                                <padding><Insets top="12" right="12" /></padding>
                                <StackPane fx:id="countdownRing"
                                           prefWidth="52" prefHeight="52"
                                           style="-fx-background-color: rgba(0,0,0,0.75);
                                                  -fx-background-radius: 26;">
                                    <Label fx:id="countdownLabel"
                                           text="10"
                                           style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                                </StackPane>
                            </StackPane>
                        </StackPane>


                        <VBox spacing="4">
                            <padding><Insets left="16" right="16" /></padding>
                            <Label text="NEXT EPISODE"
                                   style="-fx-text-fill: #e50914; -fx-font-size: 10px;
                                          -fx-font-weight: bold; -fx-letter-spacing: 2;" />
                            <Label fx:id="nextEpTitle"
                                   text="Episode Title"
                                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"
                                   wrapText="true" maxWidth="308" />
                            <Label fx:id="nextEpDesc"
                                   text=""
                                   style="-fx-text-fill: #888; -fx-font-size: 12px;"
                                   wrapText="true" maxWidth="308"
                                   maxHeight="40" />
                        </VBox>


                        <ProgressBar fx:id="countdownBar"
                                     progress="1.0"
                                     prefWidth="340" prefHeight="3"
                                     style="-fx-accent: #e50914; -fx-background-color: #333;
                                            -fx-background-radius: 0; -fx-padding: 0;" />


                        <HBox spacing="10" alignment="CENTER">
                            <padding><Insets left="16" right="16" bottom="16" /></padding>
                            <Button fx:id="playNextBtn" onAction="#handlePlayNext"
                                    style="-fx-background-color: white; -fx-text-fill: black;
                                           -fx-font-weight: bold; -fx-font-size: 13px;
                                           -fx-background-radius: 4; -fx-cursor: hand;
                                           -fx-padding: 9 22;"
                                    text="▶  Play Now"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                            <Button onAction="#handleCancelNext"
                                    style="-fx-background-color: transparent; -fx-text-fill: #aaa;
                                           -fx-border-color: #444; -fx-border-radius: 4; -fx-background-radius: 4;
                                           -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 9 16;"
                                    text="Cancel" />
                        </HBox>

                    </children>
                </VBox>

            </children>
            <padding><Insets bottom="80" right="40" /></padding>
        </VBox>

    </children>
</StackPane>
